# Input files — property data, brochures, screenshots (not tracked)
input/brochures/*
input/screenshots/*
input/urls/*
!input/brochures/.gitkeep
!input/screenshots/.gitkeep
!input/urls/.gitkeep

# Project-specific input folders (raw source files per project)
input/*/

# Generated output — not tracked in version control
output/

# Project assets (all except branding)
assets/*
!assets/branding/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Kling I2V clip cache
.cache/

# Claude Code local state
.claude/

# Secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
venv/
.venv/

# Logs and temp
*.log
tmp/
